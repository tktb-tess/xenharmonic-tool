{
  "name": "@tktb-tess/xenharmonic-tool",
  "version": "0.6.0",
  "description": "Functions and data in Xenharmonic theory",
  "author": "Tessyrrhaqt",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "keywords": [
    "xenharmonic",
    "microtonal"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tktb-tess/xenharmonic-tool.git"
  },
  "homepage": "https://github.com/tktb-tess/xenharmonic-tool/blob/main/README.md",
  "browser": "./dist/iife/bundle.min.js",
  "exports": {
    ".": {
      "import": "./dist/esm/main.js",
      "types": "./dist/esm/main.d.ts"
    },
    "./val": {
      "import": "./dist/esm/val.js",
      "types": "./dist/esm/val.d.ts"
    },
    "./monzo": {
      "import": "./dist/esm/monzo.js",
      "types": "./dist/esm/monzo.d.ts"
    },
    "./util": {
      "import": "./dist/esm/util.js",
      "types": "./dist/esm/util.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build:esm": "vite build",
    "build:iife": "vite build --config vite.config.iife.ts",
    "build": "pnpm build:esm && pnpm build:iife",
    "test": "vitest --run"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^6.0.2",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0"
}
